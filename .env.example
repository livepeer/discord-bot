# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Discord bot token (Developer Portal > Bot). Required to run live.
DISCORD_BOT_TOKEN=

# BlueClaw OpenAI-compatible API
BLUECLAW_BASE_URL=https://openai.blueclaw.network/v1
BLUECLAW_MODEL=Qwen3.6-27B
BLUECLAW_API_KEY=
# Completion token budget. Qwen3 spends tokens on reasoning, so keep this generous —
# too low truncates the reply before any JSON (finish_reason="length"). 1024 is safe.
BLUECLAW_MAX_TOKENS=1024

# Hyperlink targets shown in the flag embed.
RULES_URL=https://example.com/rules
PR_URL=https://github.com/your-org/your-repo/pulls

# Operational toggles.
# DRY_RUN=true logs the would-be flag instead of posting to Discord.
DRY_RUN=true
# Comma-separated channel IDs to moderate. Empty = every channel the bot can see.
CHANNEL_IDS=
# Skip messages shorter than this many characters (after trimming).
MIN_MESSAGE_CHARS=1
LOG_LEVEL=INFO
